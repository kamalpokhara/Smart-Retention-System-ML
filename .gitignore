# Raw data - NEVER commit large CSV files
data/raw/*
!data/raw/.gitkeep

# Processed data - we only commit small/medium standardized parquet files
data/processed/*
!data/processed/.gitkeep

# Models (never commit trained models)
models/**

# Reports and outputs
reports/**

# Python cache and bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/
ENV/
*.env

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Temporary exploration scripts (we will remove these later)
*explore*.py

# Jupyter notebooks (optional - add if you create any)
*.ipynb
.ipynb_checkpoints/

# Large files (safety)
*.csv
*.zip
*.tar.gz