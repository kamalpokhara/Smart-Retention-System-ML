# Raw data (large CSVs) - never commit
data/raw/*
!data/raw/.gitkeep

# Processed data - allow small/medium parquet for now
data/processed/*
!data/processed/.gitkeep

# Models and outputs
models/**
reports/**

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environments
venv/
.venv/
env/
ENV/

# OS & IDE
.DS_Store
Thumbs.db
.vscode/
.idea/

# Temporary large files
*.csv
*.zip
*.parquet   # remove this line later if you want to track processed parquet files